# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase - path to your service account JSON file
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Bot Settings
DEFAULT_DAILY_TIME=08:00
DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
DEFAULT_BAND_TARGET=7.0
DEFAULT_WORD_COUNT=10

# Feature flags live in Firestore `feature_flags/` collection.
# See scripts/flags.py for management.
FEATURE_FLAG_CACHE_TTL_SECONDS=60

# Observability (API)
# ENV=development uses human-friendly console logs; ENV=production emits JSON.
ENV=development
LOG_LEVEL=INFO
# ─── Local development (Firebase emulators) ──────────────────────────
# Uncomment the two lines below to route firebase-admin and client SDKs
# at the local emulators started via `make emulators`. When these are
# set, FIREBASE_CREDENTIALS_PATH / FIREBASE_CREDENTIALS_JSON are NOT
# required — the admin SDK uses a mock credential automatically.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# GOOGLE_CLOUD_PROJECT=ielts-bot-dev
